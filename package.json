{
  "name": "markdown-them",
  "displayName": "Markdown Them",
  "description": "Convert docx, pdf, html, xlsx, pptx, odt, odp, ods, rtf files to markdown in your VS Code's explorer or editor.",
  "version": "1.1.4",
  "icon": "assets/markdown-them-logo.png",
  "publisher": "the-long-ride",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-long-ride/vscode-extension-markdown-them.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "markdown-them.convertToMarkdown",
        "title": "Convert to Markdown"
      },
      {
        "command": "markdown-them.convertCurrentToMarkdown",
        "title": "Convert Current File to Markdown"
      },
      {
        "command": "markdown-them.setMaxConcurrentConversions",
        "title": "Markdown Them: Set Max Concurrent Conversions"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "markdown-them.convertToMarkdown",
          "group": "navigation",
          "when": "resourceExtname =~ /\\.(docx|pdf|html|xlsx|pptx|odt|odp|ods|rtf)$/i"
        }
      ]
    },
    "keybindings": [
      {
        "command": "markdown-them.convertCurrentToMarkdown",
        "key": "ctrl+m ctrl+d",
        "mac": "cmd+m cmd+d"
      }
    ],
    "configuration": {
      "title": "Markdown Them",
      "properties": {
        "markdown-them.maxConcurrentConversions": {
          "type": "integer",
          "default": 6,
          "minimum": 1,
          "maximum": 16,
          "description": "Maximum number of files converted simultaneously when using 'Convert to Markdown'. Range: 1–16."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle:vscode",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle:vscode": "esbuild ./src/vscode/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "bundle": "npm run bundle:vscode",
    "clean:node-package": "node -e \"require('fs').rmSync('nodejs-package/dist',{recursive:true,force:true})\"",
    "build:node-package": "npm run clean:node-package && tsc -p ./tsconfig.node-package.json",
    "prepare:artifacts": "node -e \"require('fs').mkdirSync('artifacts',{recursive:true})\"",
    "pack:node-package": "npm run build:node-package && npm run prepare:artifacts && npm pack ./nodejs-package --pack-destination ./artifacts",
    "pack:vsix": "vsce package --no-dependencies",
    "pack:all": "npm run pack:vsix && npm run pack:node-package",
    "publish:vsix": "npm run pack:vsix"
  },
  "dependencies": {
    "@opendocsg/pdf2md": "^0.2.6",
    "fast-xml-parser": "^5.8.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "officeparser": "^6.1.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "fast-uri": "^3.1.2",
    "tmp": "^0.2.4",
    "fast-csv": "^4.3.6"
  },
  "keywords": [],
  "author": "",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/the-long-ride/vscode-extension-markdown-them/issues"
  },
  "homepage": "https://github.com/the-long-ride/vscode-extension-markdown-them#readme"
}
